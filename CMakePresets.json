{
  "$comment": [
    "SPDX-FileCopyrightText: 2026 Thomas Mathys",
    "SPDX-License-Identifier: LGPL-2.1-or-later"
  ],
  "version": 10,
  "configurePresets": [
    {
      "name": "dev-base",
      "description": "Development/CI with warnings enabled",
      "hidden": true,
      "cacheVariables": {
        "argp_standalone_BUILD_TESTING": "ON",
        "argp_standalone_ENABLE_WARNINGS": "ON"
      }
    },
    {
      "name": "dev-linux",
      "inherits": "dev-base"
    },
    {
      "name": "dev-linux-clang",
      "inherits": "dev-linux",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang"
      }
    },
    {
      "name": "dev-linux-gcc",
      "inherits": "dev-linux",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc"
      }
    },
    {
      "name": "dev-linux-mingw-32",
      "inherits": "dev-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "i686-w64-mingw32-gcc",
        "CMAKE_SYSTEM_NAME": "Windows",
        "CMAKE_CROSSCOMPILING_EMULATOR": "wine"
      }
    },
    {
      "name": "dev-linux-mingw-64",
      "inherits": "dev-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "x86_64-w64-mingw32-gcc",
        "CMAKE_SYSTEM_NAME": "Windows",
        "CMAKE_CROSSCOMPILING_EMULATOR": "wine"
      }
    },
    {
      "name": "dev-windows",
      "inherits": "dev-base"
    },
    {
      "name": "dev-macos",
      "inherits": "dev-base"
    }
  ]
}
